      "title": "EC2 Instances",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT COUNT(*) AS value FROM ec2_instances WHERE recorded_at=(SELECT MAX(recorded_at) FROM ec2_instances);", "refId": "A", "queryType": "table" }]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "sqlite" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }, "id": 2,
