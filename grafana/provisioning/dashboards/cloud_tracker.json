      "targets": [{ "rawQueryText": "SELECT COUNT(*) AS value FROM rds_instances WHERE recorded_at=(SELECT MAX(recorded_at) FROM rds_instances);", "refId": "A", "queryType": "table" }]
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "sqlite" },
