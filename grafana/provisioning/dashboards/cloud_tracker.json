      "title": "S3 Buckets",
      "type": "stat",
      "targets": [{ "rawQueryText": "SELECT COUNT(*) AS value FROM s3_buckets WHERE recorded_at=(SELECT MAX(recorded_at) FROM s3_buckets);", "refId": "A", "queryType": "table" }]
    },
